# Copy this file to .env and fill in values from Google Cloud Console
# (APIs & Services -> Credentials -> your OAuth 2.0 Web application client)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
PORT=3001
REDIRECT_URI=http://localhost:3001/api/auth/callback
CLIENT_URL=http://localhost:5173

# Multi-User Authentication & Security
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
ENCRYPTION_KEY=replace_with_64_hex_chars_for_aes_256_gcm
TOKEN_ENCRYPTION_KEY=replace_with_64_hex_chars_for_aes_256_gcm

# Cookie Configuration (Set COOKIE_DOMAIN=yourdomain.com in production)
COOKIE_DOMAIN=
COOKIE_SECURE=false
CORS_ORIGIN=http://localhost:5173

# Database & Storage
DATA_DIR=./data
